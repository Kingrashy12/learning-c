# Check if all required arguments are present
if !check_var("1") or !check_var("2") or !check_var("3")
  echo "$COLOR_RED‚ùå Usage: zash exec run.zash <source_file.c> <utils_file.c> <output_executable_name>$COLOR_RESET"
  exit 1
end

set sourceFile = $1
set utilsPath = $2
set outPutName = $3

# Check if source file exists
if !exists($sourceFile)
  echo "$COLOR_RED‚ùå Source file not found: $sourceFile$COLOR_RESET"
  exit 1
end

# Check if utils file exists
if !exists($utilsPath)
  echo "$COLOR_RED‚ùå Utils file not found: $utilsPath$COLOR_RESET"
  exit 1
end

echo "$COLOR_CYAN‚õèÔ∏è  Compiling $sourceFile with utils from $utilsPath...$COLOR_RESET"

# Compile with error output captured
exec gcc $sourceFile $utilsPath -o $outPutName;

if $EXIT_CODE != 0 
  echo "$COLOR_RED‚ùå Compilation failed with exit code $EXIT_CODE$COLOR_RESET"
  exit 1
end 

echo "$COLOR_GREEN‚úÖ Compilation successful! Executable: $outPutName$COLOR_RESET"

# Clear screen before running the executable
clear_stdout()

echo "$COLOR_CYANüöÄ Running $outPutName...$COLOR_RESET"
exec $outPutName;

if $EXIT_CODE != 0 
  echo "$COLOR_RED‚ùå Execution failed with exit code $EXIT_CODE$COLOR_RESET"
  exit 1
else
  echo "$COLOR_GREEN‚úÖ Execution completed successfully!$COLOR_RESET"
end